{
  "agent": "router-host-name",
  "port": 7331,
  "clackToken": "replace-with-shared-secret",
  "gateway": {
    "url": "ws://127.0.0.1:18789",
    "token": "replace-with-local-gateway-token"
  },
  "routes": {
    "agent-a": {
      "gateway": "local",
      "sessionKey": "agent:agent-a:main"
    },
    "agent-b": {
      "gateway": "local-secondary",
      "sessionKey": "agent:agent-b:main"
    },
    "remote-agent": {
      "gateway": "https://remote-router.example.com",
      "sessionKey": "agent:remote-agent:main"
    }
  },
  "gateways": {
    "local-secondary": {
      "url": "ws://127.0.0.1:19789",
      "token": "replace-with-secondary-gateway-token"
    }
  }
}
