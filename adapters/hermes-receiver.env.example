# Clack Hermes receiver config.
# Copy to /home/aaron/clack-gateway/adapters/hermes-receiver.env on EX.

CLACK_HERMES_RECEIVER_HOST=127.0.0.1
CLACK_HERMES_RECEIVER_PORT=15300
CLACK_HERMES_SPOOL_DIR=/home/aaron/clack-gateway/hermes-receiver
CLACK_HERMES_LOG_DIR=/home/aaron/clack-gateway/hermes-receiver/logs
CLACK_HERMES_SESSION_PREFIX=clack
CLACK_HERMES_PROFILES_JSON={"zari":"zari","alf":"alf"}

HERMES_PYTHON=/home/aaron/.hermes/hermes-agent/venv/bin/python
HERMES_MODULE=hermes_cli.main
