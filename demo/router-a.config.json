{
  "routerName": "demo-router-a",
  "port": 17331,
  "auth": {
    "sharedToken": "demo-shared-token"
  },
  "adapters": {
    "to-router-b": {
      "type": "remote-http",
      "baseUrl": "http://127.0.0.1:17332",
      "path": "/route",
      "authHeader": "X-Clack-Token"
    }
  },
  "routes": {
    "agent-b": {
      "adapter": "to-router-b",
      "target": "agent-b"
    }
  }
}
