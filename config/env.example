# Clack Gateway environment file
# Copy to /opt/clack-gateway/config/env (strip the .example suffix)
# Set permissions immediately: chmod 600 /opt/clack-gateway/config/env
# Inject real secrets at boot from Infisical — never commit this file with real values.
# No secret values should appear in gateway.yml, systemd unit text, or install logs.

NODE_ENV=production
CLACK_CONFIG=/opt/clack-gateway/config/gateway.yml
CLACK_LOG_DIR=/opt/clack-gateway/logs
CLACK_DATA_DIR=/opt/clack-gateway/data

# Bootstrap secret — pull from Infisical: /clack/bootstrap-secret
# This is the ONLY place this value should appear on disk.
CLACK_BOOTSTRAP_SECRET=

# Optional: override port without editing gateway.yml
# CLACK_PORT=15200
